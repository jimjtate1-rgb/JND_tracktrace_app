# Copy to .env and edit. NONE of these are required for SQLite dev mode.
SECRET_KEY='change-me-in-production'
DEBUG=True
# In production set DEBUG=False and a strong SECRET_KEY.
# CSRF_TRUSTED_ORIGINS is auto-set from RENDER_EXTERNAL_HOSTNAME on Render;
# set it manually for a custom domain, e.g. https://track.example.com
CSRF_TRUSTED_ORIGINS=
ALLOWED_HOSTS=127.0.0.1,localhost

# Leave unset to use SQLite. For PostgreSQL (enables full-text search):
# DATABASE_URL=psql://tta:tta123@127.0.0.1:5432/tracktraceapi

# Only needed for the Celery beat weather refresh:
# REDIS_LOCATION=redis://localhost:6379/0

# OpenWeatherMap key. Without it, weather fetching is skipped gracefully.
WEATHER_API_KEY=

# --- Carrier feed (DCSA Track & Trace v2) ---
# Point at a DCSA-compliant carrier endpoint, e.g. Maersk / Hapag-Lloyd / CMA CGM / COSCO.
FEED_PROVIDER=dcsa
DCSA_BASE_URL=
DCSA_API_KEY=
DCSA_API_KEY_HEADER=API-Key
DCSA_CARRIER_NAME=
DCSA_CARRIER_SCAC=

# --- Air cargo feed (IATA Cargo-IMP FSU) ---
AIR_FEED_BASE_URL=
AIR_FEED_API_KEY=
AIR_FEED_API_KEY_HEADER=API-Key

# --- DCSA inbound webhooks (auto-updates) ---
DCSA_WEBHOOK_SECRET=
DCSA_WEBHOOK_SIGNATURE_HEADER=Notification-Signature

# --- Air inbound webhooks (auto-updates) ---
AIR_WEBHOOK_SECRET=
AIR_WEBHOOK_SIGNATURE_HEADER=X-Signature

# --- TrackCargo aggregator (ocean + air, one key) ---
TRACKCARGO_API_KEY=
TRACKCARGO_BASE_URL=https://api.trackcargo.com
TRACKCARGO_WEBHOOK_SECRET=
TRACKCARGO_WEBHOOK_SIGNATURE_HEADER=X-Signature
# Set FEED_PROVIDER=trackcargo to route all lookups through TrackCargo.
FEED_PROVIDER=
